{
  "name": "polashi-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Authoritative game server for Polashi (Battle of Plassey) hidden-role multiplayer game",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "migrate": "node --env-file-if-exists=.env --import tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "pg-mem": "^3.0.4",
    "socket.io-client": "^4.7.5",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
