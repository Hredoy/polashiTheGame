# Copy to .env. If DATABASE_URL is omitted the server uses an in-memory store (dev only).
PORT=3000
CORS_ORIGIN=*
# Secret used to sign session tokens. MUST be set to a long random value in production.
SESSION_SECRET=dev-secret-change-me
# Session token lifetime (ms). Default 30 days. Token is rotated on every connect.
SESSION_TTL_MS=2592000000
# Turn timeout (ms) for stalled VOTING/MISSION phases (janitor auto-resolves).
TURN_TIMEOUT_MS=60000
# Delete finished/abandoned rooms idle longer than this (ms). Default 1 hour.
ROOM_TTL_MS=3600000
 DATABASE_URL=postgres://postgres:@localhost:5432/polashiTheGame
# Optional: enable multi-instance fan-out via the Socket.IO Redis adapter.
 REDIS_URL=redis://localhost:6379
