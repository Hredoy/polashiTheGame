# Copy to .env. If DATABASE_URL is omitted the server uses an in-memory store (dev only).
PORT=3000
CORS_ORIGIN=*
# Secret used to sign session tokens. MUST be set to a long random value in production.
SESSION_SECRET=dev-secret-change-me
# Turn timeout (ms) for stalled VOTING/MISSION phases.
TURN_TIMEOUT_MS=60000
# DATABASE_URL=postgres://user:pass@localhost:5432/polashi
